# Ignore everything by default
/*

# Keep repository metadata and publishable files
!.gitignore
!README.md
!LICENSE
!pyproject.toml
!uv.lock
!run_augmentation.sh
!.github/
.github/*
!.github/workflows/
.github/workflows/*
!.github/workflows/ci.yml
!.github/workflows/publish.yml

# Keep only the core package entry points
!src/
src/*
!src/polyaug/
src/polyaug/*
!src/polyaug/__init__.py
!src/polyaug/augmentor.py
!src/polyaug/helper.py
!src/polyaug/cli.py
!tests/
tests/*
!tests/test_imports.py
